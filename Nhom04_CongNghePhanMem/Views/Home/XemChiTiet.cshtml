@using Nhom04_CongNghePhanMem.Models
@model SANPHAM

@{
    ViewBag.Title = "Chi tiết sản phẩm";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    var dsCD = ViewBag.dsCD as List<SANPHAM>;
    string[] sizes = Model.KICHTHUOC?.Split(',') ?? new string[] { };
    string[] colors = Model.MAUSAC?.Split(',') ?? new string[] { };
}

<div class="container mt-4">
    @if (ViewBag.StopSale != null)
    {
        <div class="alert alert-danger fw-bold text-center mb-3">
            @ViewBag.StopSale
        </div>
    }

    @if (ViewBag.OutOfStock != null)
    {
        <div class="alert alert-warning fw-bold text-center mb-3">
            @ViewBag.OutOfStock
        </div>
    }

    <h2 class="text-center mb-4 text-danger fw-bold">Chi tiết sản phẩm</h2>

    <div class="row p-4 rounded shadow-sm" style="background:#ffe9e0">

        <!-- Ảnh sản phẩm -->
        <div class="col-md-5 text-center">
            <img src="~/Content/Images/@Model.HINHANH" class="img-fluid rounded shadow" style="max-height:400px; object-fit:cover;" />
        </div>

        <!-- Thông tin sản phẩm -->
        <div class="col-md-7 mt-3 mt-md-0">

            <h3 class="fw-bold">@Model.TENSP</h3>

            <p class="mb-2">
                <strong>Đánh giá:</strong>
                @{
                    int sao = (int)(Model.DIEMTB ?? 5);
                    for (int i = 0; i < sao; i++)
                    {
                        @:<span style="color:gold; font-size:1.2rem;">★</span>
                    }
                }
            </p>

            <p class="mb-2"><strong>Giá:</strong> @String.Format("{0:N0} VNĐ", Model.GIABAN)</p>
            <p class="mb-3"><strong>Mô tả:</strong> @Model.MOTA</p>
            <p><strong>Số lượng còn:</strong> @Model.SOLUONGTON</p>
            <hr />
            @if (ViewBag.StopSale == null && ViewBag.OutOfStock == null)
            {
                <!-- Form Thêm vào giỏ hàng -->
                <form id="frmAddCart" action="@Url.Action("ThemVaoGioHang","Home")" method="post"
                      data-id="@Model.MASP"
                      data-name="@Model.TENSP"
                      data-price="@Model.GIABAN"
                      data-image="@Model.HINHANH">

                    <input type="hidden" name="id" value="@Model.MASP" />
                    <input type="hidden" name="size" id="selectedSize" value="@sizes.FirstOrDefault()" />
                    <input type="hidden" name="mau" id="selectedColor" value="@colors.FirstOrDefault()" />
                    <!-- Số lượng mua -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Số lượng mua:</label>
                        <input type="number" name="soLuong" id="soluong" value="1" min="1" max="@Model.SOLUONGTON" class="form-control w-25" />
                    </div>


                    <!-- Size -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Size:</label><br />
                        @foreach (var s in sizes)
                        {
                            <button type="button" class="btn btn-outline-primary btn-sm me-1 mb-1 size-btn @(s == sizes.FirstOrDefault() ? "active" : "")">@s</button>
                        }
                    </div>

                    <!-- Màu sắc -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Màu sắc:</label>
                        <div class="d-flex flex-wrap gap-2 mt-2">
                            @for (int i = 0; i < colors.Length; i++)
                            {
                                var color = colors[i].Trim();
                                var radioId = "colorRadio" + i;
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="colorRadio" id="@radioId" value="@color" @(i == 0 ? "checked" : "")>
                                    <label class="form-check-label" for="@radioId">@color</label>
                                </div>
                            }
                        </div>
                    </div>

                    <button type="submit" class="btn btn-pink">Thêm vào giỏ hàng</button>
                </form>
            }
            else
            {
                <div class="alert alert-secondary text-center fw-bold mt-4">
                    Không thể đặt hàng sản phẩm này.
                </div>
            }


        </div>
    </div>

    <!-- Sản phẩm liên quan -->
    @if (dsCD != null && dsCD.Count > 0)
    {
        <h3 class="mt-5 mb-3 text-danger fw-bold">Sản phẩm liên quan</h3>
        <div class="row">
            @foreach (var item in dsCD)
            {
                <div class="col-6 col-md-3 mb-4">
                    <div class="card shadow-sm h-100">
                        <img src="~/Content/Images/@item.HINHANH" class="card-img-top" style="height:200px; object-fit:cover;" />
                        <div class="card-body text-center d-flex flex-column justify-content-between">
                            <h6 class="card-title">@item.TENSP</h6>
                            <p class="text-danger fw-bold">@String.Format("{0:N0} VNĐ", item.GIABAN)</p>
                            <a href="@Url.Action("XemChiTiet", "Home", new { id = item.MASP })" class="btn btn-pink-outline">Xem chi tiết</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/Content/JS/JavaScript.js"></script>
    <style>
        .size-btn.active {
            background-color: #0d6efd;
            color: #fff;
            border-color: #0d6efd;
        }

      
        .btn-pink {
            background-color: #e797b0;
            color: white !important;
            border: 2px solid #e797b0;
            font-weight: 600;
            padding: 6px 15px;
            border-radius: 8px;
            transition: 0.25s;
        }

        .btn-pink:hover {
            background-color: #a0181c;
            border-color: #a0181c;
        }

        .btn-pink-outline {
            background-color: white;
            color: #e797b0 !important;
            border: 2px solid #e797b0;
            font-weight: 600;
            padding: 6px 15px;
            border-radius: 8px;
            transition: 0.25s;
            text-decoration: none; /* bỏ gạch chân */
        }

            .btn-pink-outline:hover {
                background-color: #e797b0;
                color: white !important;
                text-decoration: none; /* bỏ gạch chân khi hover */
            }

        .btn-custom {
            background-color: #8ca0c4; /* màu nền xanh nhạt */
            color: white; /* chữ màu trắng */
            border: 2px solid #d35a5a; /* viền đỏ */
            border-radius: 6px; /* bo góc */
            font-weight: 600; /* chữ đậm vừa phải */
            padding: 8px 20px; /* khoảng cách trên dưới và trái phải */
            text-decoration: none; /* bỏ gạch chân */
            display: inline-block;
            transition: 0.3s;
        }

            .btn-custom:hover {
                background-color: #7b90b8; /* màu nền tối hơn khi hover */
                border-color: #a0181c; /* viền đỏ đậm hơn */
                color: white;
            }
    

    </style>
}
