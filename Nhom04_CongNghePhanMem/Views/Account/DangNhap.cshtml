

@{
    ViewBag.Title = "DangNhap";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}
@using Nhom04_CongNghePhanMem.Models;
@model TAIKHOAN

<div id="successMessage" data-message="@TempData["SuccessMessage"]"></div>
<div class="container py-5" style="background-color:#fff7e6;">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-md-11 col-sm-12">
            <div class="row bg-white p-4 rounded-4 shadow-sm align-items-center">

                <!-- Cột ảnh -->
                <div class="col-lg-5 col-md-5 text-center mb-4 mb-md-0">
                    <img src="~/Content/Images/6login.jpg"
                         class="img-fluid rounded-4" />
                </div>

                <!-- Cột form -->
                <div class="col-lg-7 col-md-7">
                    <h2 class="fw-bold mb-4"
                        style="font-family: 'Pony', sans-serif; font-size: 36px;">
                        Đăng nhập
                    </h2>
                    <form id="frmDangNhap" action="/Account/DangNhap" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">Tên đăng nhập hoặc Email</label>
                            <input type="text" id="loginInput" name="loginInput" class="form-control rounded-pill p-3"
                                   style="background:#f2c6d4;border:none;" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Mật khẩu</label>
                            <input type="password" id="passwordInput" name="MATKHAU" class="form-control rounded-pill p-3"
                                   style="background:#f2c6d4;border:none;" />
                        </div>

                        <div class="text-center">
                            <button type="submit"
                                    class="btn btn-pink"
                                    style="background:#b71818; width: 160px;">
                                Đăng nhập
                            </button>
                            <p class="mt-3">
                                Nếu chưa có tài khoản vui lòng
                                <a href="@Url.Action("DangKy", "Account")"
                                   class="text-danger text-decoration-none">
                                    Đăng ký
                                </a>
                            </p>
                        </div>

                    </form>

                </div>

            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>

        document.addEventListener('DOMContentLoaded', function () {

            // Hiển thị thông báo đăng ký thành công
            const msgDiv = document.getElementById('successMessage');
            if (msgDiv) {
                const message = msgDiv.getAttribute('data-message');
                if (message) {
                    alert(message); // alert xuất hiện ngay khi load
                }
            }

            // Xử lý lưu username vào LocalStorage khi submit login
            const form = document.getElementById('frmDangNhap');
            form.addEventListener('submit', function () {
                const username = document.getElementById('loginInput').value;
                localStorage.setItem('username', username);
                console.log("Đã lưu username vào LocalStorage:", username);
            });

            // Hiển thị username nếu đã lưu
            const savedUser = localStorage.getItem('username');
            if (savedUser) {
                console.log("Người dùng đã đăng nhập trước đó:", savedUser);
            }

        });



    </script>
}

<style>
    .btn-pink {
        background-color: #e797b0;
        color: white !important;
        border: 2px solid #e797b0;
        font-weight: 600;
        padding: 6px 15px;
        border-radius: 8px;
        transition: 0.25s;
    }

        .btn-pink:hover {
            background-color: #a0181c;
            border-color: #a0181c;
        }

    .btn-pink-outline {
        background-color: white;
        color: #e797b0 !important;
        border: 2px solid #e797b0;
        font-weight: 600;
        padding: 6px 15px;
        border-radius: 8px;
        transition: 0.25s;
        text-decoration: none; /* bỏ gạch chân */
    }

        .btn-pink-outline:hover {
            background-color: #e797b0;
            color: white !important;
            text-decoration: none; /* bỏ gạch chân khi hover */
        }

    .btn-custom {
        background-color: #8ca0c4; /* màu nền xanh nhạt */
        color: white; /* chữ màu trắng */
        border: 2px solid #d35a5a; /* viền đỏ */
        border-radius: 6px; /* bo góc */
        font-weight: 600; /* chữ đậm vừa phải */
        padding: 8px 20px; /* khoảng cách trên dưới và trái phải */
        text-decoration: none; /* bỏ gạch chân */
        display: inline-block;
        transition: 0.3s;
    }

        .btn-custom:hover {
            background-color: #7b90b8; /* màu nền tối hơn khi hover */
            border-color: #a0181c; /* viền đỏ đậm hơn */
            color: white;
        }
</style>
