@using Nhom04_CongNghePhanMem.Models
@model IEnumerable<KHACHHANG>

@{
    ViewBag.Title = "Quản lý khách hàng";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<style>
    .kh-wrapper {
        background: #fdf5e9;
        border-radius: 16px;
        padding: 20px 25px 25px;
        margin-top: 20px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.05);
    }

    .kh-title {
        font-size: 22px;
        font-weight: 700;
        color: #a0181c;
        text-transform: uppercase;
        margin-bottom: 20px;
    }

    .kh-search-box {
        margin-bottom: 15px;
    }

        .kh-search-box input {
            max-width: 300px;
            display: inline-block;
        }

    .table-kh thead {
        background: #d78787;
        color: white;
        vertical-align: middle !important;
    }

    .table-kh td {
        vertical-align: middle !important;
    }
    /* FULL HỒNG */
    .btn-pink {
        background-color: #e797b0;
        color: white !important;
        border: 2px solid #e797b0;
        font-weight: 600;
        padding: 6px 15px;
        border-radius: 8px;
        transition: 0.25s;
    }

        .btn-pink:hover {
            background-color: #a0181c;
            border-color: #a0181c;
        }

    /* OUTLINE HỒNG */
   
    .btn-pink-outline {
        background-color: white;
        color: #e797b0 !important;
        border: 2px solid #e797b0;
        font-weight: 600;
        padding: 6px 15px;
        border-radius: 8px;
        transition: 0.25s;
        text-decoration: none; /* bỏ gạch chân */
    }

        .btn-pink-outline:hover {
            background-color: #e797b0;
            color: white !important;
            text-decoration: none; /* bỏ gạch chân khi hover */
        }


    .tag-success {
        color: #4CAF50;
        font-weight: bold;
    }
</style>

<div class="container-fluid mt-4">
    <div class="row">

        <div class="col-md-3">
            @{ Html.RenderPartial("~/Views/Admin/Sidebar.cshtml"); }
        </div>

        <div class="col-md-9">
            <div class="kh-wrapper">
                <div class="row">
                    <div class="col-md-8">
                        <div class="kh-title">QUẢN LÝ KHÁCH HÀNG</div>
                    </div>
                </div>

                @using (Html.BeginForm("QuanLyKhachHang", "Admin", FormMethod.Get))
                {
                    <div class="kh-search-box">

                        <input type="text"
                               name="search"
                               class="form-control"
                               value="@Request["search"]"
                               placeholder="Nhập tên, email hoặc SĐT khách hàng" />
                        <button type="submit" class="btn-pink " style="margin-left:5px;">Tìm</button>
                        @Html.ActionLink("Quay lại", "QuanLyKhachHang", null,
                            new { @class = "btn-pink-outline", style = "margin-left:5px;" })
                    </div>
                }

                <table class="table table-bordered table-striped table-kh">
                    <thead>
                        <tr>
                            <th style="width:10%">Mã KH</th>
                            <th style="width:20%">Họ tên</th>
                            <th style="width:15%">Số điện thoại</th>
                            <th style="width:25%">Email</th>
                            <th style="width:20%">Địa chỉ</th>
                            <th style="width:10%"></th>
                        </tr>
                    </thead>


                    @foreach (var kh in Model)
                    {
                        <tr>
                            <td class="text-center">@kh.MAKH_MAHOA</td>
                            <td>@kh.HOTENKH</td>
                            <td class="text-center">@kh.SDT_KH</td>
                            <td>@kh.EMAIL_KH</td>
                            <td>@kh.DIACHI_KH</td>
                            <td class="text-center">
                                @Html.ActionLink("Chi tiết", "ChiTietKhachHang", "Admin",
                                    new { id = kh.MAKH }, new { @class = "btn-pink-outline" })
                            </td>
                        </tr>
                    }
                </table>
            </div>

        </div>
    </div>
</div>





