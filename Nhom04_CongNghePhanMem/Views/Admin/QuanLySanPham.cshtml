@using Nhom04_CongNghePhanMem.Models
@model IEnumerable<SANPHAM>

@{
    ViewBag.Title = "Quản lý sản phẩm";
    Layout = "~/Views/Shared/_UserLayout.cshtml"; 
}

<style>
    .sp-wrapper {
        background: #fdf5e9;
        border-radius: 12px;
        padding: 20px 25px 25px;
        margin-top: 15px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.05);
    }

    .order-title {
        font-size: 22px;
        font-weight: 700;
        color: #a0181c;
        text-transform: uppercase;
        margin-bottom: 20px;
    }

    .sp-search input {
        max-width: 320px;
    }

    .sp-table thead tr {
        background: #d78787;
        color: #fff;
    }

    .sp-table thead th {
        border-color: #d78787 !important;
    }

    .sp-table th, .sp-table td {
        vertical-align: middle !important;
    }
    .dm-table thead tr {
        background: #d78787; /* Màu giống hình */
        color: white;
    }
    /* FULL HỒNG */
    .btn-pink {
        background-color: #e797b0;
        color: white !important;
        border: 2px solid #e797b0;
        font-weight: 600;
        padding: 6px 15px;
        border-radius: 8px;
        transition: 0.25s;
    }

        .btn-pink:hover {
            background-color: #a0181c;
            border-color: #a0181c;
        }

    /* OUTLINE HỒNG */
    /* OUTLINE HỒNG */
    .btn-pink-outline {
        background-color: white;
        color: #e797b0 !important;
        border: 2px solid #e797b0;
        font-weight: 600;
        padding: 6px 15px;
        border-radius: 8px;
        transition: 0.25s;
        text-decoration: none; /* bỏ gạch chân */
    }

        .btn-pink-outline:hover {
            background-color: #e797b0;
            color: white !important;
            text-decoration: none; /* bỏ gạch chân khi hover */
        }


    .btn-red-outline {
        background-color: white; /* nền trong */
        color: #a0181c; /* chữ đỏ */
        border: 2px solid #a0181c; /* viền đỏ */
    }

        .btn-red-outline:hover {
            background-color: #a0181c; /* nền đỏ khi hover */
            color: white; /* chữ trắng khi hover */
        }
</style>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3">
            @{ Html.RenderPartial("~/Views/Admin/Sidebar.cshtml"); }
        </div>

        <div class="col-md-9">
            <div class="sp-wrapper">
                <!-- header -->
                <h2 class="order-title">Quản lý sản phẩm</h2> <br /> <div class="row" style="margin-bottom:15px">
                    <div class="col-md-6" style="margin-left:50px">
                        @using (Html.BeginForm("QuanLySanPham", "Admin", FormMethod.Get))
                        {<div class="form-inline d-flex">
                                <input type="text" name="search" class="form-control" style="width:300px;margin-right:5px" value="@(ViewBag.Search ?? "")" placeholder="Nhập mã sản phẩm cần tìm" />
                                <button type="submit" class="btn-pink" style="margin-left:10px">Tìm</button>
                                @Html.ActionLink("Quay lại", "QuanLySanPham", null, new { @class = "btn-pink-outline", style = "margin-left:5px" })
                            </div>}
                    </div> 
                <div class="col-md-4 text-end" style="margin-left:100px">
                @Html.ActionLink("Thêm sản phẩm", "ThemSanPham", "Admin", null, new { @class = "btn-pink-outline" }) </div>
                </div>

                <!-- bảng sản phẩm -->
                <table class="table table-bordered table-striped table-hover sp-table">
                    <thead>
                        <tr>
                            <th style="width:80px">Mã SP</th>
                            <th>Tên sản phẩm</th>
                            <th style="width:160px">Danh mục</th>
                            <th style="width:120px">Giá bán</th>
                            <th style="width:90px">Số lượng</th>
                            <th style="width:80px">Ảnh</th>
                            <th style="width:180px">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sp in Model)
                        {
                            <tr>
                                <td>@sp.MASP_MAHOA</td>
                                <td>@sp.TENSP</td>
                                <td>@(sp.LOAISANPHAM != null ? sp.LOAISANPHAM.TENLOAI : "")</td>
                                <td>@String.Format("{0:0,0} đ", sp.GIABAN)</td>
                                <td>@sp.SOLUONGTON</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(sp.HINHANH))
                                    {
                                        <img src="~/Content/Images/@sp.HINHANH"
                                             style="width:60px;height:auto;border-radius:4px" />
                                    }
                                </td>
                                <td>
                                    @Html.ActionLink("Sửa", "SuaSanPham", "Admin",
                                        new { id = sp.MASP },
                                        new { @class = "btn-pink-outline" })

                                    @Html.ActionLink("Xóa", "XoaSanPham", "Admin",
                                        new { id = sp.MASP },
                                        new
                                             {
                                            @class = "btn btn-danger btn-sm",
                                            onclick = "return confirm('Xóa sản phẩm này?');",
                                            style = "margin-left:5px"
                                        })
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>


    </div>
</div>

